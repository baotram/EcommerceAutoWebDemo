<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<suite name="SauceDemo Cross Browser Suite" parallel="tests" thread-count="2">
    
    <test name="Chrome Test Execution">
        <parameter name="browser" value="chrome" />
        <classes>
            <class name="com.saucedemo.tests.LoginTests" />
            <class name="com.saucedemo.tests.CheckoutTests" />
        </classes>
    </test>
    
    <test name="Firefox Test Execution">
        <parameter name="browser" value="firefox" />
        <classes>
            <class name="com.saucedemo.tests.LoginTests" />
            <class name="com.saucedemo.tests.CheckoutTests" />
        </classes>
    </test>
    
</suite>
